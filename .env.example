# Environment Configuration for git-debug-oracle

# Qdrant Configuration
# Required: Hostname or IP address of Qdrant server
# Setup Qdrant first:
#   Local Docker: docker run -p 6333:6333 -p 6334:6334 qdrant/qdrant:latest
#   Qdrant Cloud: https://qdrant.tech/cloud/
#   Local Python: pip install qdrant-client (local mode)
QDRANT_HOST=localhost

# Optional: Port number for Qdrant gRPC API (default: 6333)
QDRANT_PORT=6333

# Optional: Name of Qdrant collection to store code chunks (default: git_debug_oracle)
QDRANT_COLLECTION=git_debug_oracle

# Optional: API key for Qdrant Cloud (only needed if using cloud, not local)
# QDRANT_API_KEY=

# Embedding Configuration
# Optional: Which embedding model to use (default: voyage-code-2)
# Options: voyage-code-2, text-embedding-3-small
EMBEDDING_MODEL=voyage-code-2

# Required: API key for embedding provider (Voyage AI or OpenAI)
EMBEDDING_API_KEY=your_embedding_api_key_here

# Claude API Configuration
# Required: API key for Claude API to generate fix proposals
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Optional: Claude model to use for fix generation (default: claude-sonnet-4-20250514)
CLAUDE_MODEL=claude-sonnet-4-20250514

# Repository Configuration
# Required: Absolute path to Git repository to index
REPO_PATH=/path/to/your/repository

# Optional: Git branch to watch for new commits during incremental indexing (default: main)
WATCH_BRANCH=main

# Webhook Configuration
# Optional: Shared secret for validating webhook requests (if None, no validation)
# WEBHOOK_SECRET=

# Optional: Port number for FastAPI webhook server (default: 8000)
WEBHOOK_PORT=8000

# Chunking Configuration
# Optional: Maximum number of characters per code chunk (default: 1000)
CHUNK_SIZE=1000

# Optional: Number of overlapping characters between adjacent chunks (default: 200)
CHUNK_OVERLAP=200

# Retrieval Configuration
# Optional: Number of top results to retrieve from Qdrant for each query (default: 5)
TOP_K=5

# Optional: Number of days to consider a commit "recent" for recency weighting (default: 30)
RECENT_COMMIT_WINDOW=30

# Optional: Maximum number of code chunks to include in fix generation context (default: 10)
MAX_CONTEXT_CHUNKS=10

# Logging Configuration
# Optional: Minimum log level to output (default: INFO)
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
