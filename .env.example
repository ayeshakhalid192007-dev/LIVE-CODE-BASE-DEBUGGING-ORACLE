# Environment Configuration for git-debug-oracle
# Essential variables required to run the server

# Repository Configuration
# Required: Absolute path to Git repository to index
REPO_PATH=/home/ayesha-khalid/LIVE-CODE-BASE-DEBUGGING-ORACLE

# Qdrant Configuration
# Required: Hostname or IP address of Qdrant server (localhost for local setup)
QDRANT_HOST=localhost

# Required: Port number for Qdrant gRPC API (default: 6333 for local)
QDRANT_PORT=6333

# Optional: API key for Qdrant Cloud (only needed if using cloud, not local Docker)
# Leave empty for local Qdrant instance
QDRANT_API_KEY=

# Embedding Configuration
# Required: API key for embedding provider (Voyage AI or OpenAI)
EMBEDDING_API_KEY=your_embedding_api_key_here

# Claude API Configuration
# Required: API key for Claude API to generate fix proposals
ANTHROPIC_API_KEY=your_anthropic_api_key_here
