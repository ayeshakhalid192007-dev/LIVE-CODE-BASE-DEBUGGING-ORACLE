# Docker Compose Environment Configuration
# Copy this file to .env and fill in your values
# docker-compose will automatically load these variables

# ============================================================================
# QDRANT CONFIGURATION
# ============================================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=git_debug_oracle
QDRANT_API_KEY=

# ============================================================================
# API KEYS (REQUIRED)
# ============================================================================
# Get from: https://console.anthropic.com/account/keys
ANTHROPIC_API_KEY=sk-ant-

# Embedding API key (choose one)
# Voyage AI: https://www.voyageai.com/
# OpenAI: https://platform.openai.com/api-keys
EMBEDDING_API_KEY=

# ============================================================================
# EMBEDDING MODEL SELECTION
# ============================================================================
# Options: voyage-code-2 (recommended for code), text-embedding-3-small
EMBEDDING_MODEL=voyage-code-2

# ============================================================================
# REPOSITORY CONFIGURATION
# ============================================================================
# Absolute path to git repository to index
REPO_PATH=/repo

# Git branch to watch for incremental indexing
WATCH_BRANCH=main

# ============================================================================
# WEBHOOK CONFIGURATION
# ============================================================================
# Port for webhook endpoint
WEBHOOK_PORT=8000

# Optional: Shared secret for webhook signature validation
# If set, webhook requests must include X-Webhook-Signature header
WEBHOOK_SECRET=

# ============================================================================
# CODE CHUNKING CONFIGURATION
# ============================================================================
# Maximum characters per code chunk
CHUNK_SIZE=1000

# Overlapping characters between adjacent chunks
CHUNK_OVERLAP=200

# ============================================================================
# RETRIEVAL CONFIGURATION
# ============================================================================
# Number of top results to retrieve from vector search
TOP_K=5

# Number of days to consider a commit "recent" for recency weighting
RECENT_COMMIT_WINDOW=30

# Maximum number of code chunks to include in fix generation context
MAX_CONTEXT_CHUNKS=10

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ============================================================================
# CLAUDE CONFIGURATION
# ============================================================================
# Claude model for fix generation
CLAUDE_MODEL=claude-sonnet-4-20250514
